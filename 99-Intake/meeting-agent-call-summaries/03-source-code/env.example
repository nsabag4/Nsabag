# ==== סוכן יומן — סבג נדל"ן · הגדרות ====
# העתק קובץ זה לקובץ בשם .env ומלא את ארבעת הערכים הראשונים.
# .env לעולם לא עולה לגיט (מוגן ב-.gitignore).

# --- ארבעת המפתחות (חובה) ---
BOT_TOKEN=
NAHI_TELEGRAM_ID=
GROQ_API_KEY=
MONDAY_API_TOKEN=

# --- מאנדיי (אומת חי מול החשבון ב-07.07.2026 — ממתין לאישור נחי) ---
# שער הקלט והנתב (חדר המיון)
MONDAY_INTAKE_BOARD_ID=5094858663
# מנהל משימות חכם
MONDAY_TASKS_BOARD_ID=5094863814
INTAKE_GROUP_TITLE=🎙️ סיכומי שיחות
TASKS_GROUP_TITLE=📥 נכנס מהסוכן
TASK_INITIAL_STATUS=חדש
# חדר המיון הוא לוח חי — יצירת הקבוצה בו רק באישור נחי. אחרי שאישר: yes
INTAKE_GROUP_AUTOCREATE=no

# --- תיקיית קליטה של הקלטות שיחה (Google Drive for Desktop) ---
# ברירת מחדל לפיתוח: תיקיית inbox בתוך הפרויקט. אחרי הקמת הסנכרון מהטלפון —
# החלף לנתיב האמיתי, למשל: G:\My Drive\CallRecordings
INBOX_PATH=inbox
# הקלטות שתאריכן מוקדם מזה מדולגות (מגן מפני עיבוד כל ההיסטוריה בסנכרון הראשון)
INBOX_MIN_DATE=

# --- זיהוי איש קשר ותיקים + מניעת כפילויות ---
# לוח אנשי קשר ולוח תיקי הלקוחות (מאסטר) — לאיתור כרטיס ותיקים מהשיחה
MONDAY_CONTACTS_BOARD_ID=1494474506
MONDAY_FILES_BOARD_ID=5099714404
# זיהוי כרטיס איש קשר לפי טלפון/שם (yes/no)
LOOKUP_CLIENT=yes
# מניעת יצירת משימה כפולה כשקיימת דומה בלוח (yes/no)
DEDUP_TASKS=yes
# הודעת הוואטסאפ המוכנה בכפתור הנודניק (ללקוח שמחכה לחזרה)
NUDGE_WA_TEXT=מתנצל, עדיין לא הספקתי לחזור אליך. אפשר קצת יותר מאוחר? אם זה דחוף — אפשר לכתוב לי כאן 🙏

# --- מתקדם (אפשר להשאיר ריק/כמו שהוא) ---
# ערוצים שעוברים דרך שער האישור בטלגרם לפני כתיבה למאנדיי (מופרד בפסיקים)
APPROVAL_CHANNELS=שיחה
# כמה שעות עד תזכורת על סיכום שממתין לאישור
REMINDER_HOURS=4
# כל כמה שניות סריקת ביטחון של תיקיית הקליטה
RESCAN_SECONDS=120
# נתיב מלא ל-claude.exe / ffmpeg.exe אם אינם ב-PATH
CLAUDE_BIN=
FFMPEG_BIN=
# מיפוי ידני של עמודות (JSON): {"date":"col_id","channel":"col_id","client":"col_id","summary":"col_id","source":"col_id"}
COLUMN_MAP_INTAKE=
# מיפוי ידני של עמודות משימה (JSON): {"date":"col_id","priority":"col_id","status":"col_id"}
COLUMN_MAP_TASKS=
# תרגום דחיפות מהחילוץ לתוויות הלוח
PRIORITY_MAP={"דחוף":"דחוף","גבוה":"דחוף","רגיל":"רגיל"}
