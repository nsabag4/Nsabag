# ================= תזכורן – הגדרות =================
# העתק קובץ זה לקובץ חדש בשם: .env  ומלא את הערכים.

# --- טלגרם (חובה) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- יומן גוגל: כתובת סודית בפורמט iCal (חובה) ---
CALENDAR_ICS_URL=

# --- monday.com (רשות בשלב ראשון, נדרש לשיחות חוזרות) ---
# חשוב: צור טוקן חדש. אל תשתמש בטוקן ישן שנחשף בקבצים.
MONDAY_API_TOKEN=
MONDAY_CALLBACKS_BOARD_ID=
MONDAY_STATUS_COLUMN_ID=status
MONDAY_PHONE_COLUMN_ID=phone
PENDING_STATUS_TEXTS=לחזור ללקוח,ממתין לחזרה
# לוח משימות לפי אזור (רשות). אם ריק, ישתמש בלוח השיחות.
MONDAY_ERRANDS_BOARD_ID=
MONDAY_ZONE_COLUMN_ID=

# --- Google Maps Routes API (רשות – בלי זה יש הערכת נסיעה קבועה) ---
GOOGLE_MAPS_API_KEY=

# --- כתובת הבית: נקודת מוצא כשאין מיקום עדכני מהטלפון ---
HOME_ADDRESS=פתח תקווה

# --- סוד לאימות בקשות מהטלפון. המצא מחרוזת ארוכה ואקראית ---
WEBHOOK_SECRET=

# --- כוונון זמנים (בדקות) ---
PARKING_BUFFER_MIN=10
WALKING_BUFFER_MIN=5
ALERT_LEAD_MIN=15
DEFAULT_TRAVEL_MIN=30
MINUTES_PER_CALL=15
LOCATION_MAX_AGE_MIN=20

# --- שעות שקט: אין התראות (פורמט: 23-07). ריק = פעיל תמיד ---
QUIET_HOURS=23-07

# --- תעדוף חכם בכניסה לרכב (דרך Claude CLI מקומי, בלי מפתח) ---
SMART_PRIORITY=1
SMART_PRIORITY_TIMEOUT_SEC=60
SMART_PRIORITY_POOL=15
CLAUDE_BIN=
MONDAY_URGENCY_COLUMN_ID=
MONDAY_DUE_COLUMN_ID=

# --- עומסי תנועה: טום-טום (רשמי, חינם, בלי כרטיס) ---
TOMTOM_API_KEY=
WAZE_ENABLED=0
